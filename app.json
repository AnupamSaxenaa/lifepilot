{
  "expo": {
    "name": "LifePilot Beta",
    "slug": "lifepilot",
    "version": "vjasper1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": [
      "lifepilot",
      "com.anupam.lp",
      "com.googleusercontent.apps.753694130355-8bhkicmdd6qqu9esu09qo5c9dv8ab3vi"
    ],
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.anupam.lp",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow $(PRODUCT_NAME) to securely transcribe your voice commands using native speech recognition.",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to access your microphone so you can speak to the AI assistant.",
        "NSCalendarsUsageDescription": "Allow $(PRODUCT_NAME) to read your calendar events to help you schedule tasks around your busy days."
      }
    },
    "android": {
      "package": "com.anupam.lp",
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 150
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#ffffff"
        }
      ],
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 34
          }
        }
      ],
      "./plugins/withFullScreenAlarm",
      "./plugins/withNotifeeRepo",
      "expo-speech-recognition",
      "expo-image"
    ],
    "experiments": {
      "reactCompiler": false
    },
    "extra": {
      "eas": {
        "projectId": "f79f9e16-1938-4c95-a8db-cc580b62f081"
      }
    },
    "owner": "doublethreecompany",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f79f9e16-1938-4c95-a8db-cc580b62f081"
    }
  }
}
